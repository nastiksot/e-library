{% extends 'layout.main.html.twig' %}
{# @var \App\Service\Manager\BookManager bookManager #}


{% block breadcrumbs %}
    {% set breadcrumbs = [
        {'url': path('crud.book.list'), 'title': 'Books', 'active': true},
    ] %}
    {{ parent() }}
{% endblock %}

{% block content %}
{#    <a href="{{ path('crud.book.add') }}" class="btn btn-success mb-2">Add</a>#}
    <div class="float-right mb-2 mr-2">
        {% include 'default/_partials/search-form.html.twig' with {'action': path('books') } %}
    </div>

    <table class="table">
        <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Title</th>
            <th scope="col">Description</th>
            <th scope="col">Author</th>
{#            <th scope="col">Actions</th>#}
        </tr>
        </thead>
        <tbody>

        {% for book in books %}
            <tr>
                <th scope="row">{{ book.id }}</th>
                <td>{{ book.title }}</td>
                <td>{{ book.description }}</td>
                <td>
                    {% set authors = bookManager.authors(book.id) %}
                    {% for author in authors %}
                        {{ author.first_name }} {{ author.last_name }} <br/>
                    {% endfor %}
                </td>
{#                <td>#}
{#                    <a href="{{ path('crud.book.edit', {'id': book.id}) }}" class="btn btn-success">Edit</a>#}
{#                    <a href="{{ path('crud.book.delete', {'id': book.id}) }}" class="btn btn-danger">Delete</a>#}
{#                </td>#}
            </tr>
        {% endfor %}

        </tbody>
    </table>
    <div class="pagination">
        {{ knp_pagination_render(books) }}
    </div>
{% endblock %}

