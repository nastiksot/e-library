{% extends 'layout.main.html.twig' %}


{% block breadcrumbs %}
    {% set breadcrumbs = [
        {'url': path('crud.book.list'), 'title': 'Books'},
        {'url': path('crud.book.add'), 'title': 'Add', 'active': true},
    ] %}
    {{ parent() }}
{% endblock %}

{% block content %}

    <form action="{{ path('crud.book.add') }}" method="post" novalidate="novalidate">
        {{ form_rest(form) }}
        <button type="submit" class="btn btn-success">Submit</button>
    </form>
{% endblock %}

