{% extends 'layout.main.html.twig' %}


{% block breadcrumbs %}
    {% set breadcrumbs = [
        {'url': path('admin.list'), 'title': 'Admins', 'active': true},
    ] %}
    {{ parent() }}
{% endblock %}

{% block content %}
    <a href="{{ path('admin.add') }}" class="btn btn-success mb-2">Add</a>
    <div class="float-right mb-2 mr-2">
        {% include 'default/_partials/search-form.html.twig' with {'action': path('admin.list') }  %}
    </div>

    <table class="table">
        <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Username</th>
            <th scope="col">Email</th>
            <th scope="col">Actions</th>
        </tr>
        </thead>
        <tbody>

        {% for admin in admins %}
            <tr>
                <th scope="row">{{ admin.id }}</th>
                <td>{{ admin.first_name }}</td>
                <td>{{ admin.last_name }}</td>
                <td>{{ admin.username }}</td>
                <td>{{ admin.email }}</td>
                <td>
                    <a href="{{ path('admin.edit', {'id': admin.id}) }}" class="btn btn-success">Edit</a>
                    <a href="{{ path('admin.delete', {'id': admin.id}) }}" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        {% endfor %}

        </tbody>
    </table>
    <div class="pagination">
        {{ knp_pagination_render(admins) }}
    </div>
{% endblock %}

