{% extends 'layout.main.html.twig' %}


{% block breadcrumbs %}
    {% set breadcrumbs = [
        {'url': path('reader.list'), 'title': 'Readers'},
        {'url': path('reader.add'), 'title': 'Add', 'active': true},
    ] %}
    {% include 'default/_partials/breadcrumbs.html.twig' %}
{% endblock %}

{% block content %}

    <form action="{{ path('reader.add') }}" method="post" novalidate="novalidate">
        {{ form_rest(form) }}
        <button type="submit" class="btn btn-success">Submit</button>
    </form>
{% endblock %}

